{
  "entities": {
    "Audit": {
      "title": "Audit Report",
      "description": "An audit report generated by the autonomous agent swarm.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who requested the audit."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The time the audit was completed."
        },
        "srs": {
          "type": "string",
          "description": "The system overview provided."
        },
        "req": {
          "type": "string",
          "description": "The user requirements provided."
        },
        "url": {
          "type": "string",
          "description": "The target URL audited."
        },
        "concurrency": {
          "type": "number",
          "description": "The concurrency/TPS setting used."
        },
        "results": {
          "type": "array",
          "description": "The raw feedback from each agent."
        }
      },
      "required": ["userId", "timestamp", "results"]
    }
  },
  "firestore": {
    "/audits/{auditId}": {
      "schema": "Audit",
      "description": "Collection of audit reports."
    }
  }
}
